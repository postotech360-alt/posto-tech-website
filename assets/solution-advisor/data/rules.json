[
  {
    "id": "display-classroom-baseline",
    "priority": 130,
    "conditions": {
      "roomType": "classroom"
    },
    "actions": {
      "remove": ["display_65_ifp", "display_75_ifp", "display_86_ifp"],
      "add": ["smart_eblackboard"]
    },
    "rationale": "Classroom profiles start with a smart e-blackboard style teaching surface for better instructional flow."
  },
  {
    "id": "display-nonclass-small",
    "priority": 128,
    "conditions": {
      "all": [
        { "field": "roomType", "in": ["meeting", "training", "boardroom", "seminar"] },
        { "field": "roomSize", "equals": "small" }
      ]
    },
    "actions": {
      "remove": ["display_75_ifp", "display_86_ifp", "smart_eblackboard"],
      "add": ["display_65_ifp"]
    },
    "rationale": "Small rooms are best matched with a 65-inch interactive display for readable and efficient collaboration."
  },
  {
    "id": "display-nonclass-medium",
    "priority": 127,
    "conditions": {
      "all": [
        { "field": "roomType", "in": ["meeting", "training", "boardroom", "seminar"] },
        { "field": "roomSize", "equals": "medium" }
      ]
    },
    "actions": {
      "remove": ["display_65_ifp", "display_86_ifp", "smart_eblackboard"],
      "add": ["display_75_ifp"]
    },
    "rationale": "Medium rooms typically require a 75-inch display to maintain front-of-room clarity."
  },
  {
    "id": "display-nonclass-large",
    "priority": 126,
    "conditions": {
      "all": [
        { "field": "roomType", "in": ["meeting", "training", "boardroom", "seminar"] },
